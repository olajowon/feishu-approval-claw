# 飞书审批Claw · 环境变量示例
# 复制为 .env 并填写真实值，也可以在管理后台「系统配置」页面直接修改（优先级更高）

# == 飞书应用配置 ==============================================================
# 主应用 App ID（飞书开发者后台创建）
APP_ID=cli_xxxxxxxxxxxxxxxx
# 主应用 App Secret
APP_SECRET=your_app_secret
# OAuth 回调地址（用于 /auth 授权流程，需与飞书后台配置一致）
REDIRECT_URI=http://localhost:9999/callback
# 飞书开放平台域名（私有化部署时修改）
FEISHU_HOST=https://open.feishu.cn

# == 飞书审批配置 ==============================================================
# 需要监听的审批定义 code，多个用英文逗号分隔
APPROVAL_CODES=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# 预检查节点名称（与飞书审批流程中的节点名保持一致）
PRE_CHECK_NODE_NAME=预检查

# == 飞书群配置 ================================================================
# Openclaw Bot App ID（工单群中自动 @的机器人）
WORKER_BOT_APP_ID=cli_xxxxxxxxxxxxxxxx
# Openclaw Bot App Secret
WORKER_BOT_APP_SECRET=your_worker_bot_app_secret
# 默认处理人，建群时自动拉入，多个用英文逗号分隔
# 支持 open_id（ou_ 开头）、邮箱（含 @）或手机号，启动时自动解析为 open_id
WORKER_USER_IDS=zhangsan@company.com,lisi@company.com
# 群主兼代理操作人（同样支持 open_id / 邮箱 / 手机号）
WORKER_ADMIN_ID=zhangsan@company.com
# 工单群自动解散天数
GROUP_TTL_DAYS=3

# == 运维配置 ==================================================================
# 告警 Webhook（飞书机器人，出错时推送告警，留空则不推送）
ALERT_WEBHOOK=

# == 管理后台（仅从 .env 读取，不会出现在后台配置页面）=========================
HTTP_PORT=9999
ADMIN_USER=
ADMIN_PASS=
